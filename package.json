{
  "name": "remix-relay",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "deploy": "turbo deploy",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "lint": "turbo lint",
    "release": "turbo build --filter='@remix-relay/react' --filter='@remix-relay/server' && changeset publish",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@remix-relay/eslint-config": "workspace:*",
    "@remix-relay/typescript-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.16"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.13"
  }
}
