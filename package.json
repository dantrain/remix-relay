{
  "name": "remix-relay",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "deploy": "turbo deploy",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "lint": "turbo lint",
    "release": "turbo build --filter='@remix-relay/react' --filter='@remix-relay/server' && changeset publish",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@remix-relay/eslint-config": "workspace:*",
    "@remix-relay/typescript-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "prettier": "^3.8.1",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.9.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.1"
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "graphql": "17.0.0-alpha.14"
      }
    },
    "patchedDependencies": {
      "@pothos/core@4.12.0": "patches/@pothos__core@4.12.0.patch",
      "@apollo/server@5.5.0": "patches/@apollo__server@5.5.0.patch"
    }
  }
}
